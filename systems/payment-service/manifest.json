    {
      "id": "ledger-db",
      "label": "ledger-db",
      "type": "postgres",
      "origin": "create-database",
      "position": {
        "x": 422,
        "y": 224
      },
      "metrics": [
        {
          "label": "connections",
          "query": "sum(pg_stat_database_numbackends{job=\"ledger-db\"})",
          "unit": ""
        },
        {
          "label": "commits/s",
          "query": "sum(rate(pg_stat_database_xact_commit{job=\"ledger-db\"}[1m]))",
          "unit": "/s"
        },
        {
          "label": "rows fetch/s",
          "query": "sum(rate(pg_stat_database_tup_fetched{job=\"ledger-db\"}[1m]))",
          "unit": "/s"
        }
      ],
      "health": {
        "query": "pg_up{job=\"ledger-db\"}",
        "rules": [
          {
            "color": "red",
            "when": "value < 1"
          },
          {
            "color": "green",
            "when": "value >= 1"
          }
        ]
      },
      "schemaModels": [
        "Account",
        "Transaction",
        "LedgerEntry",
        "Refund",
        "Payout",
        "PayoutReadiness"
      ]
    },
