{
  "system_id": "llm-app",
  "name": "Llm App",
  "prometheus_base": "/api/prometheus",
  "poll_interval_ms": 4000,
  "nodes": [
    {
      "id": "lb",
      "label": "nginx LB",
      "type": "load_balancer",
      "position": {
        "x": -24,
        "y": 155
      },
      "metrics": []
    },
    {
      "id": "prometheus",
      "label": "Prometheus",
      "type": "prometheus",
      "origin": "create-prometheus",
      "position": {
        "x": -23,
        "y": 253
      },
      "metrics": [
        {
          "label": "targets up",
          "query": "sum(up)",
          "unit": ""
        },
        {
          "label": "series",
          "query": "prometheus_tsdb_head_series",
          "unit": ""
        },
        {
          "label": "ingest",
          "query": "rate(prometheus_tsdb_head_samples_appended_total[1m])",
          "unit": "/s"
        },
        {
          "label": "api req",
          "query": "sum(rate(prometheus_http_requests_total[1m]))",
          "unit": "/s"
        }
      ],
      "health": {
        "query": "up{job=\"prometheus\"}",
        "rules": [
          {
            "color": "red",
            "when": "value < 1"
          },
          {
            "color": "green",
            "when": "value >= 1"
          }
        ]
      }
    },
    {
      "id": "user-db",
      "label": "user-db",
      "type": "postgres",
      "origin": "create-database",
      "position": {
        "x": 50,
        "y": 779
      },
      "metrics": [
        {
          "label": "connections",
          "query": "sum(pg_stat_database_numbackends{job=\"user-db\"})",
          "unit": ""
        },
        {
          "label": "commits/s",
          "query": "sum(rate(pg_stat_database_xact_commit{job=\"user-db\"}[1m]))",
          "unit": "/s"
        },
        {
          "label": "rows fetch/s",
          "query": "sum(rate(pg_stat_database_tup_fetched{job=\"user-db\"}[1m]))",
          "unit": "/s"
        }
      ],
      "health": {
        "query": "pg_up{job=\"user-db\"}",
        "rules": [
          {
            "color": "red",
            "when": "value < 1"
          },
          {
            "color": "green",
            "when": "value >= 1"
          }
        ]
      },
      "schemaModels": [
        "User"
      ]
    },
    {
      "id": "chat-db",
      "label": "chat-db",
      "type": "postgres",
      "origin": "create-database",
      "position": {
        "x": 470,
        "y": 809
      },
      "metrics": [
        {
          "label": "connections",
          "query": "sum(pg_stat_database_numbackends{job=\"chat-db\"})",
          "unit": ""
        },
        {
          "label": "commits/s",
          "query": "sum(rate(pg_stat_database_xact_commit{job=\"chat-db\"}[1m]))",
          "unit": "/s"
        },
        {
          "label": "rows fetch/s",
          "query": "sum(rate(pg_stat_database_tup_fetched{job=\"chat-db\"}[1m]))",
          "unit": "/s"
        }
      ],
      "health": {
        "query": "pg_up{job=\"chat-db\"}",
        "rules": [
          {
            "color": "red",
            "when": "value < 1"
          },
          {
            "color": "green",
            "when": "value >= 1"
          }
        ]
      },
      "schemaModels": [
        "Chat",
        "Message",
        "UserMessage"
      ]
    },
    {
      "id": "chat-service",
      "label": "chat-service",
      "type": "service",
      "origin": "create-service",
      "position": {
        "x": 65,
        "y": 464
      },
      "metrics": [
        {
          "label": "req/s",
          "query": "sum(rate(http_requests_total{job=\"chat-service\"}[1m]))",
          "unit": "/s"
        },
        {
          "label": "p95",
          "query": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"chat-service\"}[1m])) by (le)) * 1000",
          "unit": "ms"
        },
        {
          "label": "in-flight",
          "query": "sum(http_requests_in_flight{job=\"chat-service\"})",
          "unit": ""
        },
        {
          "label": "errors",
          "query": "(sum(rate(http_requests_total{job=\"chat-service\",status=~\"5..\"}[1m])) or vector(0)) / clamp_min(sum(rate(http_requests_total{job=\"chat-service\"}[1m])), 0.0001)",
          "unit": "%",
          "scale": 100
        }
      ],
      "health": {
        "query": "up{job=\"chat-service\"}",
        "rules": [
          {
            "color": "red",
            "when": "value < 1"
          },
          {
            "color": "green",
            "when": "value >= 1"
          }
        ]
      }
    },
    {
      "id": "user-messages-stream",
      "label": "user-messages-stream",
      "type": "kafka",
      "origin": "create-event-stream",
      "position": {
        "x": 1209,
        "y": 652
      },
      "metrics": [
        {
          "label": "topics",
          "query": "count(count by (topic)(kafka_topic_partitions{job=\"user-messages-stream\",topic!~\"__.*\"})) or vector(0)",
          "unit": ""
        },
        {
          "label": "partitions",
          "query": "sum(kafka_topic_partitions{job=\"user-messages-stream\",topic!~\"__.*\"}) or vector(0)",
          "unit": ""
        },
        {
          "label": "msgs/s",
          "query": "sum(rate(kafka_topic_partition_current_offset{job=\"user-messages-stream\",topic!~\"__.*\"}[1m])) or vector(0)",
          "unit": "/s"
        },
        {
          "label": "lag",
          "query": "sum(kafka_consumergroup_lag{job=\"user-messages-stream\",topic!~\"__.*\"}) or vector(0)",
          "unit": ""
        }
      ],
      "health": {
        "query": "up{job=\"user-messages-stream\"}",
        "rules": [
          {
            "color": "red",
            "when": "value < 1"
          },
          {
            "color": "green",
            "when": "value >= 1"
          }
        ]
      }
    },
    {
      "id": "chat-db-cdc",
      "label": "chat-db-cdc",
      "type": "cdc",
      "origin": "create-cdc",
      "cdcOf": "chat-db",
      "position": {
        "x": 833,
        "y": 833
      },
      "metrics": [
        {
          "label": "captured/s",
          "query": "sum(rate(cdc_events_captured_total{job=\"chat-db-cdc\"}[1m])) or vector(0)",
          "unit": "/s"
        },
        {
          "label": "produced/s",
          "query": "sum(rate(cdc_events_produced_total{job=\"chat-db-cdc\"}[1m])) or vector(0)",
          "unit": "/s"
        },
        {
          "label": "errors/s",
          "query": "sum(rate(cdc_errors_total{job=\"chat-db-cdc\"}[1m])) or vector(0)",
          "unit": "/s"
        }
      ],
      "health": {
        "query": "up{job=\"chat-db-cdc\"}",
        "rules": [
          {
            "color": "red",
            "when": "value < 1"
          },
          {
            "color": "green",
            "when": "value >= 1"
          }
        ]
      }
    },
    {
      "id": "llm-worker",
      "label": "llm-worker",
      "type": "service",
      "origin": "create-custom-service",
      "service_type": "llm_worker",
      "position": {
        "x": 666,
        "y": 230
      },
      "metrics": [
        {
          "label": "req/s",
          "query": "sum(rate(http_requests_total{job=\"llm-worker\"}[1m]))",
          "unit": "/s"
        },
        {
          "label": "p95",
          "query": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"llm-worker\"}[1m])) by (le)) * 1000",
          "unit": "ms"
        },
        {
          "label": "in-flight",
          "query": "sum(http_requests_in_flight{job=\"llm-worker\"})",
          "unit": ""
        },
        {
          "label": "errors",
          "query": "(sum(rate(http_requests_total{job=\"llm-worker\",status=~\"5..\"}[1m])) or vector(0)) / clamp_min(sum(rate(http_requests_total{job=\"llm-worker\"}[1m])), 0.0001)",
          "unit": "%",
          "scale": 100
        },
        {
          "label": "tokens/s",
          "query": "sum(rate(llm_tokens_streamed_total{job=\"llm-worker\"}[1m])) or vector(0)",
          "unit": "/s"
        },
        {
          "label": "batch",
          "query": "sum(llm_active_sequences{job=\"llm-worker\"}) or vector(0)",
          "unit": ""
        }
      ],
      "health": {
        "query": "up{job=\"llm-worker\"}",
        "rules": [
          {
            "color": "red",
            "when": "value < 1"
          },
          {
            "color": "green",
            "when": "value >= 1"
          }
        ]
      },
      "grpc": {
        "servers": [
          "Worker"
        ],
        "clients": [],
        "overrides": []
      },
      "llm": {
        "stream": "llm-worker-stream"
      },
      "replicas": {
        "instances": [
          "llm-worker-2",
          "llm-worker-3"
        ]
      }
    },
    {
      "id": "llm-worker-stream",
      "label": "llm-worker-stream",
      "type": "redis",
      "origin": "create-custom-service",
      "streamOf": "llm-worker",
      "position": {
        "x": 292,
        "y": 251
      },
      "metrics": [
        {
          "label": "clients",
          "query": "redis_connected_clients{job=\"llm-worker-stream\"}",
          "unit": ""
        },
        {
          "label": "ops/s",
          "query": "sum(rate(redis_commands_processed_total{job=\"llm-worker-stream\"}[1m]))",
          "unit": "/s"
        },
        {
          "label": "keys",
          "query": "sum(redis_db_keys{job=\"llm-worker-stream\"})",
          "unit": ""
        }
      ],
      "health": {
        "query": "redis_up{job=\"llm-worker-stream\"}",
        "rules": [
          {
            "color": "red",
            "when": "value < 1"
          },
          {
            "color": "green",
            "when": "value >= 1"
          }
        ]
      }
    },
