#!/usr/bin/env node
// WebSocket client pool for "__CLIENT__" — generated by "Add WebSockets".
//
// Runs on the HOST (no container) and connects through the tier's L4 load balancer,
// using node's built-in browser-style WebSocket client (node >= 22) — zero npm deps,
// mirroring the stdlib-only lbclient.py convention of HTTP clients.
//
//   node ws-clients/__CLIENT__.mjs --count 5 --duration 10 --rate 1
//
//   --count     clients to spawn (each connects as clientId "__CLIENT__-<i>")
//   --duration  seconds to run the send loop before closing and reporting
//   --rate      messages per second EACH connected client sends (to a random peer)
//
// Every message is { msgId, from, to, body, sentAt }; receivers dedupe by msgId.
// The last stdout line is the machine-readable report (same pattern as the HTTP
// clients' __LB_RESULTS__ sentinel):
//   __WS_RESULTS__ {"spawned":..,"connected":..,"sent":..,"delivered":..,
//                   "duplicates":..,"errors":..,"latencyMs":{"p50":..,"p95":..,"max":..}}
// The same report (plus a timestamp and the args used) is also written next to this
// script as __CLIENT__.stats.json — best-effort — so the app can show the last run's
// delivery stats no matter which driver spawned us (the API or an e2e session).
import crypto from 'node:crypto'
import fs from 'node:fs'
import path from 'node:path'
import process from 'node:process'
import { fileURLToPath } from 'node:url'

const WS_URL = process.env.WS_URL || '__WS_URL__'
const CONNECT_GRACE_MS = 10_000 // wait up to this long for the pool to connect
const DRAIN_MS = 2_000 // after the send loop stops, let in-flight deliveries land

if (typeof WebSocket === 'undefined') {
  console.error('this script needs the built-in WebSocket client — run it with Node.js 22 or newer')
  process.exit(1)
}

function parseArgs(argv) {
  const out = { count: 5, duration: 10, rate: 1 }
  for (let i = 0; i < argv.length; i++) {
    const m = /^--(count|duration|rate)$/.exec(argv[i])
    if (!m) continue
    const v = Number(argv[++i])
    if (!Number.isFinite(v) || v <= 0) {
      console.error(`invalid value for --${m[1]}`)
      process.exit(1)
    }
    out[m[1]] = Math.floor(v)
  }
  return out
}
const args = parseArgs(process.argv.slice(2))

const clients = new Map() // clientId -> { ws, connected, received: Map(msgId -> recvAt) }
const stats = { spawned: 0, connected: 0, sent: 0, delivered: 0, duplicates: 0, errors: 0 }
const latencies = []

function spawn(i) {
  const clientId = `__CLIENT__-${i}`
  const ws = new WebSocket(`${WS_URL}/?clientId=${clientId}`)
  const st = { clientId, ws, connected: false, received: new Map() }
  stats.spawned++

  ws.addEventListener('open', () => {
    st.connected = true
    stats.connected++
  })
  // on receive, key by msgId so duplicates are detected, and measure delivery latency
  ws.addEventListener('message', (ev) => {
    let msg
    try {
      msg = JSON.parse(ev.data)
    } catch {
      return
    }
    if (st.received.has(msg.msgId)) {
      stats.duplicates++
      return
    }
    st.received.set(msg.msgId, Date.now())
    stats.delivered++
    if (typeof msg.sentAt === 'number') latencies.push(Date.now() - msg.sentAt)
  })
  ws.addEventListener('close', () => {
    if (st.connected) stats.connected--
    st.connected = false
  })
  ws.addEventListener('error', () => {
    stats.errors++
  })

  clients.set(clientId, st)
  return st
}

function sendFrom(st) {
  if (!st.connected || st.ws.readyState !== WebSocket.OPEN) return
  // pick a random peer (self only when it's a pool of one)
  const ids = [...clients.keys()]
  let to = st.clientId
  if (ids.length > 1) {
    do {
      to = ids[Math.floor(Math.random() * ids.length)]
    } while (to === st.clientId)
  }
  const msg = {
    msgId: `${st.clientId}-${crypto.randomUUID()}`,
    from: st.clientId,
    to,
    body: `hello from ${st.clientId}`,
    sentAt: Date.now(),
  }
  try {
    st.ws.send(JSON.stringify(msg))
    stats.sent++
  } catch {
    stats.errors++
  }
}

function percentile(sorted, p) {
  if (!sorted.length) return null
  return sorted[Math.min(sorted.length - 1, Math.floor((p / 100) * sorted.length))]
}

let finished = false
function finish(code = 0) {
  if (finished) return
  finished = true
  for (const st of clients.values()) {
    try {
      st.ws.close()
    } catch {
      /* already closed */
    }
  }
  const sorted = [...latencies].sort((a, b) => a - b)
  const report = {
    ...stats,
    latencyMs: {
      p50: percentile(sorted, 50),
      p95: percentile(sorted, 95),
      max: sorted.length ? sorted[sorted.length - 1] : null,
    },
  }
  // persist the report next to this script (script-relative, NOT cwd-relative — the
  // API spawns us from the system dir, e2e sessions from the repo root); best-effort
  try {
    const statsPath = path.join(path.dirname(fileURLToPath(import.meta.url)), '__CLIENT__.stats.json')
    fs.writeFileSync(
      statsPath,
      JSON.stringify(
        {
          ts: new Date().toISOString(),
          args: { count: args.count, durationSeconds: args.duration, rate: args.rate },
          results: report,
        },
        null,
        2,
      ) + '\n',
    )
  } catch {
    /* stats are best-effort — never fail the run over them */
  }
  console.log('__WS_RESULTS__ ' + JSON.stringify(report))
  process.exit(code)
}

const sleep = (ms) => new Promise((r) => setTimeout(r, ms))

async function main() {
  for (let i = 1; i <= args.count; i++) spawn(i)

  // connect grace: start sending once everyone is in (or the grace runs out)
  const graceUntil = Date.now() + CONNECT_GRACE_MS
  while (stats.connected < args.count && Date.now() < graceUntil) await sleep(100)

  const timers = []
  for (const st of clients.values()) {
    timers.push(setInterval(() => sendFrom(st), Math.max(10, Math.floor(1000 / args.rate))))
  }
  await sleep(args.duration * 1000)
  timers.forEach(clearInterval)

  await sleep(DRAIN_MS) // let the last messages arrive before reporting
  finish(0)
}

// hard backstop: report whatever we have if something wedges
setTimeout(() => finish(1), (CONNECT_GRACE_MS + args.duration * 1000 + DRAIN_MS + 10_000))
main().catch((err) => {
  console.error(err?.message || err)
  finish(1)
})
